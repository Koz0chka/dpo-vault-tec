# Пример переменных окружения.
# Скопируйте в .env и задайте свои значения:
#   cp .env.example .env

# Секрет для подписи JWT. Сгенерируйте случайную строку:
#   openssl rand -base64 48
JWT_SECRET=replace-with-openssl-rand-base64-48

# Время жизни JWT-токена, минут (по умолчанию 120).
JWT_TTL_MINUTES=120
